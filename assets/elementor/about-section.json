{
  "version": "0.4",
  "title": "SNB — About Section (for Homepage)",
  "type": "section",
  "content": [
    {
      "id": "snbas_wrap",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "content_position": "middle",
        "stretch_section": "section-stretched",
        "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
        "background_background": "classic",
        "background_color": "#0B0B0B"
      },
      "elements": [
        {
          "id": "snbas_col",
          "elType": "column",
          "settings": { "column_width": { "unit": "%", "size": 100 } },
          "elements": [
            {
              "id": "snbas_html",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"snb-about\">\n  <div class=\"snb-about__inner\">\n\n    <div class=\"snb-about__text\">\n      <p class=\"snb-about__label\">OUR STORY</p>\n      <h2 class=\"snb-about__title\">Bold Flavors.<br>Real People.</h2>\n      <p class=\"snb-about__body\">Sauce N&rsquo; Bone started with one obsession &mdash; wings done right. Every bone-in, boneless, and tender that leaves our kitchen is hand-tossed in house-made sauce and cooked fresh to order. No heat lamps. No shortcuts. Just real food made with real ingredients for people who demand flavor first.</p>\n\n      <div class=\"snb-about__stats\">\n        <div class=\"snb-about__stat\">\n          <span class=\"snb-about__stat-num\">50+</span>\n          <span class=\"snb-about__stat-label\">Sauce &amp; Flavor Options</span>\n        </div>\n        <div class=\"snb-about__stat\">\n          <span class=\"snb-about__stat-num\">100%</span>\n          <span class=\"snb-about__stat-label\">Fresh. Never Frozen.</span>\n        </div>\n        <div class=\"snb-about__stat\">\n          <span class=\"snb-about__stat-num\">1</span>\n          <span class=\"snb-about__stat-label\">Rule: Flavor First.</span>\n        </div>\n      </div>\n\n      <a href=\"/menu/\" class=\"snb-btn\">See Our Menu &rarr;</a>\n    </div>\n\n    <div class=\"snb-about__img-wrap\">\n      <!-- Replace the placeholder below with your real food photo -->\n      <div class=\"snb-about__img-placeholder\">ADD YOUR PHOTO HERE</div>\n      <!-- Once you have a photo, swap to: <img src=\"YOUR-IMAGE-URL\" alt=\"Sauce N' Bone\" class=\"snb-about__img\"> -->\n    </div>\n\n  </div>\n</section>"
              }
            }
          ]
        }
      ]
    }
  ],
  "page_settings": {}
}
