{
  "version": "0.4",
  "title": "Sauce N' Bone — About Us Page",
  "type": "page",
  "content": [
    {
      "id": "snbap_hero",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "stretch_section": "section-stretched",
        "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
        "background_background": "classic",
        "background_color": "#0B0B0B"
      },
      "elements": [
        {
          "id": "snbap_hero_col",
          "elType": "column",
          "settings": { "column_width": { "unit": "%", "size": 100 } },
          "elements": [
            {
              "id": "snbap_hero_html",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"snb-about snb-about--hero\" style=\"padding: 5rem 2rem 3rem;\">\n  <div style=\"max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:2rem;\">\n    <div>\n      <h1 style=\"font-family:'Bebas Neue',sans-serif;font-size:clamp(3rem,6vw,5rem);color:#F4EEDF;line-height:0.92;letter-spacing:2px;margin:0;\">ABOUT <span style=\"color:#E03602;\">US.</span></h1>\n    </div>\n    <div style=\"max-width:480px;\">\n      <p style=\"color:#B8B0A0;font-size:1rem;line-height:1.65;margin:0;\">Real ingredients. Real people. One obsession: flavor first.<br>Here&rsquo;s the story behind Sauce N&rsquo; Bone.</p>\n    </div>\n  </div>\n</section>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "snbap_content",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "stretch_section": "section-stretched",
        "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
        "background_background": "classic",
        "background_color": "#0B0B0B"
      },
      "elements": [
        {
          "id": "snbap_content_col",
          "elType": "column",
          "settings": { "column_width": { "unit": "%", "size": 100 } },
          "elements": [
            {
              "id": "snbap_content_html",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"snb-about\">\n  <div class=\"snb-about__inner\">\n\n    <div class=\"snb-about__text\">\n      <p class=\"snb-about__label\">OUR STORY</p>\n      <h2 class=\"snb-about__title\">Bold Flavors.<br>Real People.</h2>\n      <p class=\"snb-about__body\">Sauce N&rsquo; Bone started with one obsession &mdash; wings done right. Every bone-in, boneless, and tender that leaves our kitchen is hand-tossed in house-made sauce and cooked fresh to order. No heat lamps. No shortcuts. Just real food made with real ingredients for people who demand flavor first.</p>\n      <p class=\"snb-about__body\" style=\"margin-top:-1rem;\">Whether you&rsquo;re stopping in for a quick bite, feeding the crew, or ordering online, we&rsquo;re here to make sure every visit hits different. That&rsquo;s the Sauce N&rsquo; Bone promise.</p>\n\n      <div class=\"snb-about__stats\">\n        <div class=\"snb-about__stat\">\n          <span class=\"snb-about__stat-num\">50+</span>\n          <span class=\"snb-about__stat-label\">Sauce &amp; Flavor Options</span>\n        </div>\n        <div class=\"snb-about__stat\">\n          <span class=\"snb-about__stat-num\">100%</span>\n          <span class=\"snb-about__stat-label\">Fresh. Never Frozen.</span>\n        </div>\n        <div class=\"snb-about__stat\">\n          <span class=\"snb-about__stat-num\">1</span>\n          <span class=\"snb-about__stat-label\">Rule: Flavor First.</span>\n        </div>\n      </div>\n\n      <a href=\"/menu/\" class=\"snb-btn\">See Our Menu &rarr;</a>\n    </div>\n\n    <div class=\"snb-about__img-wrap\">\n      <!-- Replace the placeholder below with your real food photo -->\n      <div class=\"snb-about__img-placeholder\">ADD YOUR PHOTO HERE</div>\n      <!-- Once you have a photo, swap to: <img src=\"YOUR-IMAGE-URL\" alt=\"Sauce N' Bone\" class=\"snb-about__img\"> -->\n    </div>\n\n  </div>\n</section>"
              }
            }
          ]
        }
      ]
    }
  ],
  "page_settings": {
    "hide_title": "yes",
    "background_color": "#0B0B0B"
  }
}
