{
  "version": "0.4",
  "title": "Sauce N' Bone — Contact Us Page",
  "type": "page",
  "content": [
    {
      "id": "snbcp_hero",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "stretch_section": "section-stretched",
        "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
        "background_background": "classic",
        "background_color": "#0B0B0B"
      },
      "elements": [
        {
          "id": "snbcp_hero_col",
          "elType": "column",
          "settings": { "column_width": { "unit": "%", "size": 100 } },
          "elements": [
            {
              "id": "snbcp_hero_html",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section style=\"background:#0B0B0B;padding:5rem 2rem 3rem;\">\n  <div style=\"max-width:960px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:2rem;\">\n    <div>\n      <h1 style=\"font-family:'Bebas Neue',sans-serif;font-size:clamp(3rem,6vw,5rem);color:#F4EEDF;line-height:0.92;letter-spacing:2px;margin:0;\">LET&rsquo;S <span style=\"color:#E03602;\">TALK.</span></h1>\n    </div>\n    <div style=\"max-width:420px;\">\n      <p style=\"color:#B8B0A0;font-size:1rem;line-height:1.65;margin:0;\">Questions, catering requests, or just want to talk wings?<br>Fill out the form and we&rsquo;ll get back to you fast.</p>\n    </div>\n  </div>\n</section>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "snbcp_content",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "stretch_section": "section-stretched",
        "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
        "background_background": "classic",
        "background_color": "#0B0B0B"
      },
      "elements": [
        {
          "id": "snbcp_content_col",
          "elType": "column",
          "settings": { "column_width": { "unit": "%", "size": 100 } },
          "elements": [
            {
              "id": "snbcp_content_html",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"snb-contact\">\n  <div class=\"snb-contact__inner\">\n\n    <!-- LEFT: Contact Info -->\n    <div>\n      <p class=\"snb-contact__label\">FIND US</p>\n      <h2 class=\"snb-contact__title\">Get In<br>Touch.</h2>\n\n      <ul class=\"snb-contact__info-list\">\n        <li class=\"snb-contact__info-item\">\n          <span class=\"snb-icon\">&#128205;</span>\n          <div>\n            <strong>Location</strong>\n            Coming Soon &mdash; Stay Tuned\n          </div>\n        </li>\n        <li class=\"snb-contact__info-item\">\n          <span class=\"snb-icon\">&#128222;</span>\n          <div>\n            <strong>Phone</strong>\n            Coming Soon\n          </div>\n        </li>\n        <li class=\"snb-contact__info-item\">\n          <span class=\"snb-icon\">&#9993;&#65039;</span>\n          <div>\n            <strong>Email</strong>\n            <a href=\"mailto:info@saucenbone.com\" style=\"color:#B8B0A0;text-decoration:none;\">info@saucenbone.com</a>\n          </div>\n        </li>\n        <li class=\"snb-contact__info-item\">\n          <span class=\"snb-icon\">&#128241;</span>\n          <div>\n            <strong>Social</strong>\n            @saucenbone\n          </div>\n        </li>\n      </ul>\n\n      <div class=\"snb-contact__hours\">\n        <p class=\"snb-contact__hours-title\">Hours</p>\n        <div class=\"snb-contact__hours-row\">\n          <span>Monday &ndash; Friday</span>\n          <span style=\"color:#F4EEDF;\">11 AM &ndash; 10 PM</span>\n        </div>\n        <div class=\"snb-contact__hours-row\">\n          <span>Saturday</span>\n          <span style=\"color:#F4EEDF;\">10 AM &ndash; 11 PM</span>\n        </div>\n        <div class=\"snb-contact__hours-row\">\n          <span>Sunday</span>\n          <span style=\"color:#F4EEDF;\">11 AM &ndash; 9 PM</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- RIGHT: Contact Form -->\n    <div class=\"snb-contact__form-wrap\">\n      <p style=\"font-family:'Bebas Neue',sans-serif;font-size:0.8rem;letter-spacing:3px;color:#C9A24A;text-transform:uppercase;margin:0 0 1.25rem;\">SEND A MESSAGE</p>\n      [metform form_id=\"271\"]\n    </div>\n\n  </div>\n</section>"
              }
            }
          ]
        }
      ]
    }
  ],
  "page_settings": {
    "hide_title": "yes",
    "background_color": "#0B0B0B"
  }
}
